PUBLIC_BASE_URL=https://krouter.example.com
HOST=0.0.0.0
PORT=4010
# Use backend/api/cli for split deployment where nginx serves dist-web.
# Leave unset or use fullstack/web when this Node process should also serve frontend assets.
# KROUTER_SERVER_MODE=backend
KIRO_WEB_DATA_DIR=.web-data
KIRO_RUNTIME_DATA_DIR=.web-data
KIRO_CONFIG_HOME=.web-data/kiro-config
KIRO_SSO_CACHE_DIR=.web-data/aws-sso-cache
KIRO_CLI_DB_PATH=.web-data/kiro-cli/data.sqlite3
APP_ENCRYPTION_KEY=replace-with-32-plus-random-bytes
SESSION_SECRET=replace-with-another-random-secret
# Optional unattended bootstrap. Leave password unset to use the first-run setup screen.
KROUTER_ADMIN_EMAIL=admin@krouter.local
# KROUTER_ADMIN_PASSWORD=change-this-password
COOKIE_SECURE=true

# Proton OTP source for web/VPS mode. Dockerfile.web installs Chromium at this path.
PROTON_BROWSER_PATH=/usr/bin/chromium
# Default is true/headless. Set false only when the VPS has a visible display/noVNC.
PROTON_BROWSER_HEADLESS=true
# Optional. Docker/root deployments use no-sandbox automatically; set this explicitly only if Chrome cannot start.
# PROTON_BROWSER_NO_SANDBOX=true
# Optional fixed CDP port. Leave empty to use a random localhost port.
# PROTON_BROWSER_DEBUG_PORT=9231

# Optional: set this for container/test deployments where machine ID changes
# should write an isolated file instead of the host OS machine-id/registry.
# KIRO_MACHINE_ID_FILE=.web-data/machine-id
# KIRO_MACHINE_ID_BACKUP_PATH=.web-data/machine-id-backup.json

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node"],
    "rootDir": "src",
    "outDir": "out-server",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "src/server/**/*.ts",
    "src/main/runtimePaths.ts",
    "src/main/proxy/**/*.ts",
    "src/main/kproxy/**/*.ts",
    "src/main/utils/**/*.ts"
  ]
}
